async function repondre() {
  const question = document.getElementById("question").value.toLowerCase();

  const response = await fetch("./questions_restaurant.json");
  const data = await response.json();

  const resultat = data.find(item =>
    item.question.toLowerCase() === question
  );

  document.getElementById("reponse").innerText =
    resultat ? resultat.reponse : "Désolé, je ne connais pas encore la réponse.";
}